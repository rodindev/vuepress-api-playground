{
  "name": "vue-api-playground",
  "version": "2.1.0",
  "type": "module",
  "description": "Interactive API playground component for Vue 3. Plug-and-play with VitePress or any Vue 3 app — automatically inherits host theme styles.",
  "author": "",
  "license": "MIT",
  "main": "./dist/vue-api-playground.cjs",
  "module": "./dist/vue-api-playground.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-api-playground.js",
      "require": "./dist/vue-api-playground.cjs"
    },
    "./styles": "./dist/vue-api-playground.css",
    "./styles/vars": "./dist/_vars.scss",
    "./styles/_vars.scss": "./dist/_vars.scss"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "vue",
    "vue3",
    "vitepress",
    "interactive",
    "api",
    "playground",
    "http",
    "rest",
    "component",
    "documentation"
  ],
  "homepage": "https://rodindev.github.io/vue-api-playground/",
  "repository": {
    "type": "git",
    "url": "https://github.com/rodindev/vue-api-playground.git"
  },
  "bugs": {
    "url": "https://github.com/rodindev/vue-api-playground/issues"
  },
  "scripts": {
    "dev": "vitepress dev docs",
    "build": "vite build && node -e \"require('node:fs').copyFileSync('src/styles/_vars.scss','dist/_vars.scss')\"",
    "preview": "vitepress preview docs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run build",
    "release": "release-it",
    "release:dry": "release-it --dry-run"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@release-it/conventional-changelog": "^10.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-vue": "^9.32.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.4.0",
    "release-it": "^18.0.0",
    "sass-embedded": "^1.83.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitepress": "^1.5.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  }
}
